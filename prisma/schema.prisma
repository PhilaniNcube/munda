// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  sessions      Session[]
  accounts      Account[]
  farms         Farm[]
}

model Farm {
  id             String          @id @default(cuid())
  name           String
  location       String?
  size           Float?
  userId         String          @map("user_id")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  crops          Crop[]
  livestock      Livestock[]
  transactions   Transaction[]
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
}

enum CropStatus {
  PLANNED
  GROWING
  HARVESTED
  FAILED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum InventoryCategory {
  EQUIPMENT
  SEEDS
  FERTILIZER
  FEED
  OTHER
}

model Crop {
  id                  String     @id @default(cuid())
  name                String
  variety             String?
  status              CropStatus @default(PLANNED)
  plantingDate        DateTime?  @map("planting_date")
  expectedHarvestDate DateTime?  @map("expected_harvest_date")
  actualHarvestDate   DateTime?  @map("actual_harvest_date")
  farmId              String     @map("farm_id")
  farm                Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
}

model Livestock {
  id           String   @id @default(cuid())
  type         String
  breed        String?
  quantity     Int      @default(0)
  healthStatus String?  @map("health_status")
  farmId       String   @map("farm_id")
  farm         Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  category    String
  amount      Float
  date        DateTime        @default(now())
  description String?
  attachments Attachment[]
  farmId      String          @map("farm_id")
  farm        Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
}

model Attachment {
  id            String       @id @default(cuid())
  url           String
  name          String?
  fileType      String?      @map("file_type")
  transactionId String?      @map("transaction_id")
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
}

model InventoryItem {
  id        String            @id @default(cuid())
  name      String
  category  InventoryCategory @default(OTHER)
  quantity  Float             @default(0)
  unit      String            @default("units")
  farmId    String            @map("farm_id")
  farm      Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
}
